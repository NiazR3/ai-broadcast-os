# ── Supabase (required for auth) ──
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service_role key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...     # anon key (frontend uses this)

# ── Finnhub (required for real-time quotes) ──
FINNHUB_API_KEY=your_finnhub_key_here

# ── Stripe (required for pro billing — Phase 2) ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_abc123

# ── Rate Limits ──
FREE_RATE_LIMIT=30
PRO_RATE_LIMIT=300

# ── Timing ──
BATCH_INTERVAL_SEC=10
SMA_REFRESH_INTERVAL=1800
ACCURACY_EVAL_INTERVAL=900
DB_CLEANUP_AGE_HOURS=48
FINNHUB_CACHE_TTL=10

# ── Batching ──
BATCH_SIZE=15
YFINANCE_TIMEOUT=20

# ── Deploy ──
ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
