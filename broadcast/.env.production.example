# =============================================================================
# Broadcast OS — Production Environment Configuration
# =============================================================================
# Copy this file to .env.production and fill in your values.
#   cp .env.production.example .env.production

# ---- Service ---------------------------------------------------------------
BROADCAST_HOST=0.0.0.0
BROADCAST_PORT=8100
BROADCAST_SERVICE_NAME=ai-broadcast-os
BROADCAST_VERSION=0.1.0

# ---- API Auth (REQUIRED for production) ------------------------------------
# Generate a strong random key: openssl rand -hex 32
BROADCAST_API_KEY=change-me-to-a-random-secret

# ---- CORS (REQUIRED for production) ----------------------------------------
# Comma-separated list of allowed frontend origins
# e.g. https://app.broadcast.dev,https://broadcast.vercel.app
BROADCAST_CORS_ORIGINS=https://app.yourdomain.com

# ---- WebSocket origins -----------------------------------------------------
# Comma-separated list of allowed WebSocket origins
BROADCAST_WEBSOCKET_ALLOWED_ORIGINS=https://app.yourdomain.com

# ---- OBS WebSocket Connection ----------------------------------------------
BROADCAST_OBS_HOST=host.docker.internal
BROADCAST_OBS_PORT=4455
# Set a strong password in OBS WebSocket settings
BROADCAST_OBS_PASSWORD=

# ---- Platform Stream Keys (fill in on dashboard after deploy) --------------
# These can be set via the API/dashboard instead of env vars
BROADCAST_TWITCH_STREAM_KEY=
BROADCAST_YOUTUBE_STREAM_KEY=
BROADCAST_FACEBOOK_STREAM_KEY=

# ---- Vercel Frontend (for local builds) ------------------------------------
# Set this when building the dashboard for production:
#   VITE_API_BASE=https://api.yourdomain.com npm run build --prefix dashboard
# Or set it in Vercel project settings as an environment variable.
